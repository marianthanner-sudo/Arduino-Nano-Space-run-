void zeichneGalaxie(int x, int y, int radius, uint16_t farbe1, uint16_t farbe2) {
  tft.fillCircle(x, y, radius/4, ST77XX_WHITE);
  for(int i=0; i<360; i+=(gewaehlteSchwierigkeit==4?30:10)) {
    float rad = i * 0.0174533;
    int px = x + cos(rad) * (radius/2 + i/12.0); int py = y + sin(rad) * (radius/4 + i/24.0);
    if (py < 212) tft.drawPixel(px, py, farbe1);
  }
}

