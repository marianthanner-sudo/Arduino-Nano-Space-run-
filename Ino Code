#include <Adafruit_GFX.h>
#include <Adafruit_ST7789.h>
#include <SPI.h>
#include <EEPROM.h> 

// Display Pins
#define TFT_CS        10
#define TFT_RST        8
#define TFT_DC         9

// Touch-Sensor Pins
#define TOUCH_LINKS   A0
#define TOUCH_RECHTS  A1

Adafruit_ST7789 tft = Adafruit_ST7789(TFT_CS, TFT_DC, TFT_RST);

const int EEPROM_ADDR = 0;       
const int EEPROM_ADDR_TIME = 4;  
const int EEPROM_ADDR_WARP = 8;  
const int EEPROM_ADDR_CMD = 12;  

// Spiel-Variablen
const int ANZAHL_SCHIENEN = 10;
const int schienenX[ANZAHL_SCHIENEN] = {12, 34, 56, 78, 100, 122, 144, 166, 188, 210}; 

const int spielerBreite = 18;
const int spielerHoehe = 16; 
int spielerSchiene = 4;
int spielerAltSchiene = 4; 
float spielerY = 195;  
float spielerAltY = 195;

// Bewegung
unsigned long letzterWechsel = 0;
const int bewegungsVerzoegerung = 140; 

// Timer für automatischen Start im Menü
unsigned long menueAuswahlZeit = 0; 
const unsigned long AUTO_START_VERZOEGERUNG = 3000; 

// Multi-Gegner / Barrieren-System
const int MAX_GEGNER = 2;
int gegnerSchiene[MAX_GEGNER];
int gegnerAltSchiene[MAX_GEGNER];
float gegnerY[MAX_GEGNER];
float gegnerAltY[MAX_GEGNER];
int aktuelleGegnerGroesse[MAX_GEGNER];
int altGegnerGroesse[MAX_GEGNER];
int anzahlAktiveGegner = 1; 

// Variablen für den WARP DRIVE Modus
float barriereY = -20;
float barriereAltY = -20;
int barriereLueckeX = 0;
bool lueckeOffen = true;
unsigned long letzterWarpBlonk = 0;
float aktuelleSpielerGeschwindigkeit = 0; 

// Variablen für den COMMANDER-MODUS (Einzelne fallende Pfeile)
int aktuellerFallenderPfeil = 0; // 0 = Links (<), 1 = Rechts (>)
float commanderPfeilY = 35;
float commanderPfeilAltY = 35;
float pfeilGeschwindigkeit = 2.0;
bool letzterZustandLinks = false;
bool letzterZustandRechts = false;
int commanderHighScore = 0;

float gegnerGeschwindigkeit = 3.5;
float basisGeschwindigkeit = 3.5; 
float geschwindigkeitsZuwachs = 0.1; 
const int MAX_GEGNER_GROESSE = 22;

// Menü-System
int gewaehlteSchwierigkeit = 0; 
int altGewaehlteSchwierigkeit = -1; 
int aktuelleMenueSeite = 1; 
int altMenueSeite = -1;

// Timer Variablen
unsigned long spielStartZeit = 0;
int verbleibendeSekunden = 0;
int zielZeitSekunden = 0; 
bool hatGewonnen = false;
int letzterTimerWert = -1; 
int angezeigterMenueTimer = -1;

// Highscores
int score = 0;
int highscore = 0;
int endlessSekunden = 0;
int endlessBestTime = 0; 
int warpHighScore = 0;

// Status-Variablen
int leben = 3;
int altLeben = -1;
bool gameOver = false;
bool imStartBildschirm = true; 

// Sterne-Hintergrund
#define ANZAHL_STERNE 30
int sterneX[ANZAHL_STERNE];
int sterneY[ANZAHL_STERNE];
uint16_t sterneFarbe[ANZAHL_STERNE];

const int galaxieX = 120;
const int galaxieY = 120;
const int galaxieRadius = 40;

// Vorab-Deklarationen
void zeichneRahmen();
void starteCountdown();
void resetGame();
void aktualisiereUI();
void zeichneMiniHerz(int x, int y);
void herzenExplosionMitte();
void aktualisiereStartBildschirmMenue();
void zeichneHintergrund();
void zeichneGalaxie(int x, int y, int radius, uint16_t farbe1, uint16_t farbe2);
void zeichneSpieler(int x, int y);
void loescheSpieler(int x, int y);
int bestimmeGegnerSchiene();
void zeichneHotbar();
bool pruefeKollisionMitGalaxie(int x, int y, int b, int h);
void repariereHintergrundBereich(int x, int y, int b, int h);
void generiereNeuenPfeil();
void zeichneEinzelPfeil(int posY, bool loeschen = false);

void setup() {
  pinMode(TFT_RST, OUTPUT);
  digitalWrite(TFT_RST, HIGH); delay(50);
  digitalWrite(TFT_RST, LOW);  delay(50);
  digitalWrite(TFT_RST, HIGH); delay(50);

  tft.init(240, 240);
  tft.setRotation(0); 
  tft.fillScreen(ST77XX_BLACK);

  pinMode(TOUCH_LINKS, INPUT);
  pinMode(TOUCH_RECHTS, INPUT);

  highscore = EEPROM.read(EEPROM_ADDR);
  if (highscore == 255) highscore = 0; 

  byte highByte = EEPROM.read(EEPROM_ADDR_TIME);
  byte lowByte = EEPROM.read(EEPROM_ADDR_TIME + 1);
  endlessBestTime = (highByte << 8) | lowByte;
  if (endlessBestTime == 65535) endlessBestTime = 0;

  warpHighScore = EEPROM.read(EEPROM_ADDR_WARP);
  if (warpHighScore == 255) warpHighScore = 0;

  commanderHighScore = EEPROM.read(EEPROM_ADDR_CMD);
  if (commanderHighScore == 255) commanderHighScore = 0;

  for (int i=0; i<ANZAHL_STERNE; i++) {
    sterneX[i] = random(10, 230);
    sterneY[i] = random(35, 210); 
    sterneFarbe[i] = tft.color565(random(100, 255), random(100, 255), random(100, 255));
  }

  zeichneRahmen();
  tft.fillRect(10, 35, 220, 195, ST77XX_BLACK);
  zeichneHintergrund(); 
  menueAuswahlZeit = millis(); 
  aktualisiereStartBildschirmMenue();
}

void loop() {
  unsigned long aktuelleZeit = millis();

  // --- STARTBILDSCHIRM / MENÜ ---
  if (imStartBildschirm) {
    bool tasteGedrueckt = false;

    if (digitalRead(TOUCH_LINKS) == HIGH) {
      if (aktuelleZeit - letzterWechsel >= bewegungsVerzoegerung) {
        if (gewaehlteSchwierigkeit > 0) { 
          gewaehlteSchwierigkeit--; 
          if (gewaehlteSchwierigkeit <= 3) aktuelleMenueSeite = 1;
          else if (gewaehlteSchwierigkeit == 4) aktuelleMenueSeite = 2;
          tasteGedrueckt = true; 
        }
        letzterWechsel = aktuelleZeit;
      }
    }

    if (digitalRead(TOUCH_RECHTS) == HIGH) {
      if (aktuelleZeit - letzterWechsel >= bewegungsVerzoegerung) {
        if (gewaehlteSchwierigkeit < 5) { 
          gewaehlteSchwierigkeit++; 
          if (gewaehlteSchwierigkeit == 4) aktuelleMenueSeite = 2;
          else if (gewaehlteSchwierigkeit == 5) aktuelleMenueSeite = 3;
          tasteGedrueckt = true; 
        }
        letzterWechsel = aktuelleZeit;
      }
    }

    if (tasteGedrueckt) {
      menueAuswahlZeit = aktuelleZeit; 
      aktualisiereStartBildschirmMenue();
      angezeigterMenueTimer = -1;
    }

    int verbleibendeMenueZeit = (AUTO_START_VERZOEGERUNG - (aktuelleZeit - menueAuswahlZeit)) / 1000 + 1;
    if (verbleibendeMenueZeit != angezeigterMenueTimer && verbleibendeMenueZeit > 0 && verbleibendeMenueZeit <= 3) {
      angezeigterMenueTimer = verbleibendeMenueZeit;
      tft.fillRect(35, 192, 170, 12, ST77XX_BLACK);
      tft.setCursor(35, 194); tft.setTextSize(1); tft.setTextColor(ST77XX_CYAN);
      tft.print("Startet in: "); tft.print(angezeigterMenueTimer); tft.print("s...");
    }

    if (aktuelleZeit - menueAuswahlZeit >= AUTO_START_VERZOEGERUNG) {
      imStartBildschirm = false; hatGewonnen = false;
      starteCountdown(); 
      resetGame();
    }
    delay(10);
    return;
  }

  // --- WINNER / GAME OVER SCREEN ---
  if (gameOver || hatGewonnen) {
    if (digitalRead(TOUCH_LINKS) == HIGH || digitalRead(TOUCH_RECHTS) == HIGH) {
      delay(100); 
      gameOver = false; hatGewonnen = false; imStartBildschirm = true;
      tft.fillRect(10, 35, 220, 195, ST77XX_BLACK);
      zeichneHintergrund(); 
      altGewaehlteSchwierigkeit = -1; altMenueSeite = -1; 
      menueAuswahlZeit = millis(); angezeigterMenueTimer = -1;
      aktualisiereStartBildschirmMenue();
    }
    delay(20); 
    return;
  }

  // --- SPIEL-UPDATE ---
  int vergangeneSekunden = (aktuelleZeit - spielStartZeit) / 1000;
  
  if (gewaehlteSchwierigkeit <= 2) { 
    verbleibendeSekunden = zielZeitSekunden - vergangeneSekunden;
    if (verbleibendeSekunden != letzterTimerWert) {
      letzterTimerWert = verbleibendeSekunden;
      aktualisiereUI(); 
    }

    if (verbleibendeSekunden <= 0) {
      hatGewonnen = true;
      tft.fillRect(10, 35, 220, 195, ST77XX_BLACK); 
      tft.setCursor(70, 80); tft.setTextColor(ST77XX_GREEN); tft.setTextSize(3); tft.println("SIEG!");
      tft.setCursor(26, 125); tft.setTextColor(ST77XX_WHITE); tft.setTextSize(2); tft.print("Mission geschafft");
      tft.setCursor(65, 155); tft.setTextColor(ST77XX_YELLOW); tft.print("Score: "); tft.println(score);
      tft.setCursor(22, 195); tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1); tft.println("Druecke L/R fuer Hauptmenue");
      return;
    }
  } else { 
    endlessSekunden = vergangeneSekunden;
    if (endlessSekunden != letzterTimerWert) {
      letzterTimerWert = endlessSekunden;
      aktualisiereUI();
    }
  }

  // --- SPIEL LOGIK ---

  if (gewaehlteSchwierigkeit == 4) {
    // ##########################################
    // MODUS 5: WARP DRIVE
    // ##########################################
    spielerAltY = spielerY;
    barriereAltY = barriereY;

    if (digitalRead(TOUCH_LINKS) == HIGH) {
      aktuelleSpielerGeschwindigkeit = 1.0; 
      tft.drawFastHLine(10, 211, 220, ST77XX_BLUE); 
    } 
    else if (digitalRead(TOUCH_RECHTS) == HIGH) {
      aktuelleSpielerGeschwindigkeit = 6.8; 
      tft.drawFastHLine(10, 211, 220, ST77XX_MAGENTA); 
    } 
    else {
      aktuelleSpielerGeschwindigkeit = 3.2; 
    }

    barriereY += aktuelleSpielerGeschwindigkeit;

    if (aktuelleZeit - letzterWarpBlonk >= 650) {
      lueckeOffen = !lueckeOffen;
      letzterWarpBlonk = aktuelleZeit;
    }

    if (barriereY > 210) {
      barriereY = 35;
      barriereLueckeX = schienenX[4]; 
      score++;
      if (score > warpHighScore) warpHighScore = score;
      aktualisiereUI();
    }

    if (barriereY + 6 >= spielerY && barriereY <= spielerY + spielerHoehe) {
      if (!lueckeOffen) {
        leben--;
        tft.fillRect(10, 35, 220, 195, ST77XX_BLACK); 
        zeichneRahmen(); zeichneHintergrund(); zeichneHotbar(); aktualisiereUI();
        barriereY = 35;

        if (leben <= 0) {
          gameOver = true;
          tft.fillRect(10, 35, 220, 195, ST77XX_BLACK); 
          tft.setCursor(45, 80); tft.setTextColor(ST77XX_RED); tft.setTextSize(3); tft.println("GAME OVER");
          tft.setCursor(55, 125); tft.setTextColor(ST77XX_WHITE); tft.setTextSize(2);
          EEPROM.write(EEPROM_ADDR_WARP, warpHighScore);
          tft.print("Tore: "); tft.println(score);
          tft.setCursor(55, 150); tft.setTextColor(ST77XX_YELLOW); tft.print("BEST: "); tft.print(warpHighScore);
          tft.setCursor(22, 190); tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1); tft.println("Druecke L/R fuer Hauptmenue");
        }
      }
    }

    if (!gameOver && !hatGewonnen) {
      tft.fillRect(10, (int)barriereAltY, 220, 7, ST77XX_BLACK);
      repariereHintergrundBereich(10, (int)barriereAltY, 220, 7);

      if (lueckeOffen) {
        tft.fillRect(10, (int)barriereY, barriereLueckeX - 22, 6, ST77XX_RED);
        tft.fillRect(barriereLueckeX + 40, (int)barriereY, 230 - (barriereLueckeX + 40), 6, ST77XX_RED);
        tft.fillRect(barriereLueckeX - 22, (int)barriereY, 4, 6, ST77XX_GREEN);
        tft.fillRect(barriereLueckeX + 36, (int)barriereY, 4, 6, ST77XX_GREEN);
      } else {
        tft.fillRect(10, (int)barriereY, 220, 6, 0xF800);
      }

      zeichneSpieler(schienenX[spielerSchiene], (int)spielerY);
      tft.drawFastHLine(10, 213, 220, ST77XX_CYAN);
    }

  } 
  else if (gewaehlteSchwierigkeit == 5) {
    // ##########################################
    // MODUS 6: COMMANDER (EINZELNE FALLENDE PFEILE)
    // ##########################################
    spielerAltSchiene = spielerSchiene;
    commanderPfeilAltY = commanderPfeilY;

    commanderPfeilY += pfeilGeschwindigkeit;

    bool tasteLinksAktuell = (digitalRead(TOUCH_LINKS) == HIGH);
    bool tasteRechtsAktuell = (digitalRead(TOUCH_RECHTS) == HIGH);
    bool fehlerPassiert = false;

    if (commanderPfeilY > 190) {
      fehlerPassiert = true;
    }

    if (tasteLinksAktuell && !letzterZustandLinks && !fehlerPassiert) {
      if (aktuellerFallenderPfeil == 0) {
        if (spielerSchiene > 0) spielerSchiene--;
        score++;
        if (score > commanderHighScore) commanderHighScore = score;
        pfeilGeschwindigkeit += 0.12; 
        aktualisiereUI();
        zeichneEinzelPfeil((int)commanderPfeilY, true); 
        tft.fillRect(10, 35, 220, 8, ST77XX_GREEN); delay(40); tft.fillRect(10, 35, 220, 8, ST77XX_BLACK);
        generiereNeuenPfeil();
      } else {
        fehlerPassiert = true;
      }
      letzterZustandLinks = true;
    }
    if (!tasteLinksAktuell) letzterZustandLinks = false;

    if (tasteRechtsAktuell && !letzterZustandRechts && !fehlerPassiert) {
      if (aktuellerFallenderPfeil == 1) {
        if (spielerSchiene < ANZAHL_SCHIENEN - 1) spielerSchiene++;
        score++;
        if (score > commanderHighScore) commanderHighScore = score;
        pfeilGeschwindigkeit += 0.12; 
        aktualisiereUI();
        zeichneEinzelPfeil((int)commanderPfeilY, true); 
        tft.fillRect(10, 35, 220, 8, ST77XX_GREEN); delay(40); tft.fillRect(10, 35, 220, 8, ST77XX_BLACK);
        generiereNeuenPfeil();
      } else {
        fehlerPassiert = true;
      }
      letzterZustandRechts = true;
    }
    if (!tasteRechtsAktuell) letzterZustandRechts = false;

    if (fehlerPassiert) {
      leben--;
      zeichneEinzelPfeil((int)commanderPfeilAltY, true);
      zeichneEinzelPfeil((int)commanderPfeilY, true);
      
      tft.fillRect(10, 35, 220, 12, ST77XX_RED); delay(60); tft.fillRect(10, 35, 220, 12, ST77XX_BLACK);
      aktualisiereUI();
      
      if (leben <= 0) {
        gameOver = true;
        tft.fillRect(10, 35, 220, 195, ST77XX_BLACK); 
        tft.setCursor(45, 80); tft.setTextColor(ST77XX_RED); tft.setTextSize(3); tft.println("GAME OVER");
        tft.setCursor(55, 125); tft.setTextColor(ST77XX_WHITE); tft.setTextSize(2);
        EEPROM.write(EEPROM_ADDR_CMD, commanderHighScore);
        tft.print("Kombos: "); tft.println(score);
        tft.setCursor(55, 150); tft.setTextColor(ST77XX_YELLOW); tft.print("BEST: "); tft.print(commanderHighScore);
        tft.setCursor(22, 190); tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1); tft.println("Druecke L/R fuer Hauptmenue");
      } else {
        generiereNeuenPfeil(); 
      }
    }

    if (!gameOver && !hatGewonnen) {
      zeichneEinzelPfeil((int)commanderPfeilAltY, true);

      if (spielerAltSchiene != spielerSchiene) {
        loescheSpieler(schienenX[spielerAltSchiene], (int)spielerY);
        repariereHintergrundBereich(schienenX[spielerAltSchiene] - 6, (int)spielerY - 6, spielerBreite + 12, spielerHoehe + 12);
      }
      
      zeichneEinzelPfeil((int)commanderPfeilY, false);
      zeichneSpieler(schienenX[spielerSchiene], (int)spielerY);
      tft.drawFastHLine(10, 213, 220, ST77XX_CYAN);
    }
  } 
  else {
    // ##########################################
    // NORMALE MODI: AUSWEICHEN MIT KI-ZIELEN
    // ##########################################
    spielerAltSchiene = spielerSchiene;
    for(int g=0; g<anzahlAktiveGegner; g++) {
      gegnerAltSchiene[g] = gegnerSchiene[g]; gegnerAltY[g] = gegnerY[g]; altGegnerGroesse[g] = aktuelleGegnerGroesse[g];
    }

    if (digitalRead(TOUCH_LINKS) == HIGH) {
      if (aktuelleZeit - letzterWechsel >= bewegungsVerzoegerung) {
        if (spielerSchiene > 0) spielerSchiene--;
        letzterWechsel = aktuelleZeit;
      }
    }

    if (digitalRead(TOUCH_RECHTS) == HIGH) {
      if (aktuelleZeit - letzterWechsel >= bewegungsVerzoegerung) {
        if (spielerSchiene < ANZAHL_SCHIENEN - 1) spielerSchiene++;
        letzterWechsel = aktuelleZeit;
      }
    }

    for (int g = 0; g < anzahlAktiveGegner; g++) {
      gegnerY[g] += gegnerGeschwindigkeit;
      float fortschritt = (gegnerY[g] - 35) / (212 - 35);
      aktuelleGegnerGroesse[g] = 4 + (constrain(fortschritt,0,1) * (MAX_GEGNER_GROESSE - 4));

      if (gegnerY[g] > 212 - aktuelleGegnerGroesse[g]) {
        gegnerY[g] = 35 - (g * 45); 

        if ((gewaehlteSchwierigkeit == 1 || gewaehlteSchwierigkeit == 2 || gewaehlteSchwierigkeit == 3) && random(0, 100) < 50) {
          gegnerSchiene[g] = spielerSchiene; 
        } else {
          gegnerSchiene[g] = bestimmeGegnerSchiene(); 
        }

        if (gewaehlteSchwierigkeit <= 2) { score++; if (score > highscore) highscore = score; }
        basisGeschwindigkeit += geschwindigkeitsZuwachs; gegnerGeschwindigkeit = basisGeschwindigkeit;
        aktualisiereUI();
      }

      if (gegnerSchiene[g] == spielerSchiene && (gegnerY[g] + aktuelleGegnerGroesse[g] >= spielerY) && (gegnerY[g] <= spielerY + spielerHoehe)) {
        leben--; 
        herzenExplosionMitte(); // Hier explodiert das Herz jetzt wieder flüssig!
        tft.fillRect(10, 35, 220, 195, ST77XX_BLACK); 
        zeichneRahmen(); zeichneHintergrund(); zeichneHotbar(); aktualisiereUI();
        gegnerGeschwindigkeit = 1.5; 

        for (int i = 0; i < anzahlAktiveGegner; i++) {
          gegnerY[i] = 35 - (i * 45); 
          gegnerSchiene[i] = bestimmeGegnerSchiene();
        }

        if (leben <= 0) {
          gameOver = true;
          tft.fillRect(10, 35, 220, 195, ST77XX_BLACK); 
          tft.setCursor(45, 80); tft.setTextColor(ST77XX_RED); tft.setTextSize(3); tft.println("GAME OVER");
          tft.setCursor(55, 125); tft.setTextColor(ST77XX_WHITE); tft.setTextSize(2);
          
          if (gewaehlteSchwierigkeit <= 2) {
            EEPROM.write(EEPROM_ADDR, highscore); tft.print("Score: "); tft.println(score);
          } else {
            if (endlessSekunden > endlessBestTime) {
              endlessBestTime = endlessSekunden;
              EEPROM.write(EEPROM_ADDR_TIME, (endlessBestTime >> 8) & 0xFF); EEPROM.write(EEPROM_ADDR_TIME + 1, endlessBestTime & 0xFF);
            }
            int m = endlessSekunden / 60; int s = endlessSekunden % 60;
            tft.print("Zeit: "); tft.print(m); tft.print(":"); tft.println(s);
          }
          tft.setCursor(22, 190); tft.setTextColor(ST77XX_CYAN); tft.setTextSize(1); tft.println("Druecke L/R fuer Hauptmenue");
        }
        break; 
      }
    }

    if (!gameOver && !hatGewonnen) {
      for (int g = 0; g < anzahlAktiveGegner; g++) {
        if (gegnerAltY[g] >= 35) {
          int altX = schienenX[gegnerAltSchiene[g]] + (18 / 2) - (altGegnerGroesse[g] / 2);
          if (gegnerAltSchiene[g] != gegnerSchiene[g] || (int)gegnerAltY[g] != (int)gegnerY[g]) {
            tft.fillRect(altX, (int)gegnerAltY[g], altGegnerGroesse[g], altGegnerGroesse[g], ST77XX_BLACK);
            repariereHintergrundBereich(altX, (int)gegnerAltY[g], altGegnerGroesse[g], altGegnerGroesse[g]);
          }
        }
      }
      if (spielerAltSchiene != spielerSchiene) {
        loescheSpieler(schienenX[spielerAltSchiene], (int)spielerY);
        repariereHintergrundBereich(schienenX[spielerAltSchiene] - 6, (int)spielerY - 6, spielerBreite + 12, spielerHoehe + 12);
      }
      for (int g = 0; g < anzahlAktiveGegner; g++) {
        if (gegnerY[g] >= 35) { 
          int zeichneX = schienenX[gegnerSchiene[g]] + (18 / 2) - (aktuelleGegnerGroesse[g] / 2);
          tft.fillRect(zeichneX, (int)gegnerY[g], aktuelleGegnerGroesse[g], aktuelleGegnerGroesse[g], ST77XX_RED);
        }
      }
      zeichneSpieler(schienenX[spielerSchiene], (int)spielerY);
      tft.drawFastHLine(10, 213, 220, ST77XX_CYAN);
    }
  }

  delay(15); 
}

void generiereNeuenPfeil() {
  aktuellerFallenderPfeil = random(0, 2); 
  commanderPfeilY = 35; 
}

void zeichneEinzelPfeil(int posY, bool loeschen) {
  int x = 102; 
  if (loeschen) {
    // Sichert ab, dass beim Überschreiben der gesamte Bereich restlos schwarz wird
    tft.fillRect(x - 2, posY - 2, 45, 26, ST77XX_BLACK);
  } else {
    tft.setTextSize(3); 
    tft.setTextColor(ST77XX_YELLOW);
    tft.setCursor(x, posY);
    if (aktuellerFallenderPfeil == 0) tft.print("<-");
    else tft.print("->");
  }
}

void starteCountdown() {
  tft.fillRect(10, 35, 220, 195, ST77XX_BLACK);
  zeichneHintergrund();
  zeichneSpieler(schienenX[spielerSchiene], (int)spielerY); 
  zeichneHotbar();
  tft.setTextSize(5); tft.setTextColor(ST77XX_YELLOW);
  for (int c = 3; c > 0; c--) {
    tft.setCursor(105, 100); tft.print(c); delay(1000);
