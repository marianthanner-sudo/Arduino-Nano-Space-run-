void herzenExplosionMitte() {
  int mitteX = 120;
  int mitteY = 120;
  
  // Riesen-Herz in der Mitte zeichnen
  tft.fillCircle(mitteX - 10, mitteY - 8, 10, ST77XX_RED); 
  tft.fillCircle(mitteX + 10, mitteY - 8, 10, ST77XX_RED);
  tft.fillTriangle(mitteX - 20, mitteY - 2, mitteX + 20, mitteY - 2, mitteX, mitteY + 22, ST77XX_RED);
  delay(140); 

  tft.fillRect(mitteX - 22, mitteY - 18, 45, 42, ST77XX_BLACK);

  // Partikel-Explosion starten
  const int ANZAHL_PARTIKEL = 35;
  int px[ANZAHL_PARTIKEL];
  int py[ANZAHL_PARTIKEL];
  float vx[ANZAHL_PARTIKEL];
  float vy[ANZAHL_PARTIKEL];

  for (int i = 0; i < ANZAHL_PARTIKEL; i++) {
    px[i] = mitteX + random(-4, 5);
    py[i] = mitteY + random(-4, 5);
    float winkel = random(0, 36) * 10 * 0.0174533;
    float geschwindigkeit = (random(12, 35) / 10.0); 
    vx[i] = cos(winkel) * geschwindigkeit;
    vy[i] = sin(winkel) * geschwindigkeit;
  }

  // Flüssige Animationsschleife ohne mathematische Abstürze
  for (int frame = 0; frame < 18; frame++) {
    for (int i = 0; i < ANZAHL_PARTIKEL; i++) {
      tft.drawPixel(px[i], py[i], ST77XX_BLACK);
      
      px[i] += (int)vx[i];
      py[i] += (int)vy[i];
      
      uint16_t partikelFarbe = ST77XX_RED;
      if (frame > 6) partikelFarbe = tft.color565(180, 40, 40);
      if (frame > 12) partikelFarbe = tft.color565(90, 0, 0);
      
      // Strict Boundary Control um Abstürze zu verhindern
      if (px[i] >= 12 && px[i] <= 228 && py[i] >= 36 && py[i] <= 210) {
        tft.drawPixel(px[i], py[i], partikelFarbe);
      }
    }
    delay(10); 
  }
}

