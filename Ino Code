void repariereHintergrundBereich(int x, int y, int b, int h) {
  if (gewaehlteSchwierigkeit != 5) {
    if (pruefeKollisionMitGalaxie(x, y, b, h)) zeichneGalaxie(galaxieX, galaxieY, galaxieRadius, ST77XX_MAGENTA, ST77XX_CYAN);
    for (int i=0; i<ANZAHL_STERNE; i++) {
      if (sterneX[i] >= x && sterneX[i] <= x+b && sterneY[i] >= y && sterneY[i] <= y+h) tft.drawPixel(sterneX[i], sterneY[i], sterneFarbe[i]);
    }
  }
}

bool pruefeKollisionMitGalaxie(int x, int y, int b, int h) {
  int dx = (x + b/2) - galaxieX; int dy = (y + h/2) - galaxieY;
  return (sqrt(dx*dx + dy*dy) <= galaxieRadius + 8);
}

